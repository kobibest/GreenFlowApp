<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="176dp"
    android:background="?attr/colorPrimary"
    android:gravity="bottom"
    android:orientation="vertical"
    android:paddingStart="@dimen/screen_padding_h"
    android:paddingEnd="@dimen/screen_padding_h"
    android:paddingTop="@dimen/spacing_xl"
    android:paddingBottom="@dimen/spacing_lg">

    <ImageView
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:contentDescription="@null"
        android:src="@drawable/ic_webhook"
        app:tint="@color/onPrimary" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_sm"
        android:text="@string/app_name"
        android:textAppearance="?attr/textAppearanceTitleLarge"
        android:textColor="@color/onPrimary"
        android:textDirection="rtl" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_xs"
        android:text="@string/nav_header_subtitle"
        android:textAppearance="?attr/textAppearanceBodySmall"
        android:textColor="@color/onPrimary"
        android:alpha="0.8"
        android:textDirection="rtl" />
</LinearLayout>
